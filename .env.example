# Copy this file to .env for local development.
# Never commit real API keys.

# Choose the hosted model provider for generated problem drafts.
HACKERPRANK_GENERATOR_PROVIDER=anthropic

# Choose the hosted model provider for tutor hints and follow-up chat.
HACKERPRANK_TUTOR_PROVIDER=anthropic

# Paste your Claude API key into .env, not this example file.
ANTHROPIC_API_KEY=replace_with_your_claude_api_key

# Optional Claude model overrides.
HACKERPRANK_ANTHROPIC_MODEL=claude-sonnet-4-20250514
HACKERPRANK_TUTOR_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional Java editor intelligence. Install Eclipse JDT LS and point here if it is not on PATH.
# macOS Homebrew example: brew install jdtls
HACKERPRANK_JAVA_LSP_ENABLED=true
HACKERPRANK_JAVA_LSP_COMMAND=
HACKERPRANK_JAVA_LSP_STARTUP_TIMEOUT_MS=20000
HACKERPRANK_JAVA_LSP_DIAGNOSTICS_SETTLE_MS=1200
